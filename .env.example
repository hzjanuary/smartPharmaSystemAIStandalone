# Smart Pharma AI Service - Environment Configuration
# Copy this file to .env and update with your actual values

# Database Configuration
# SQLite for development (default - no external DB required)
DATABASE_URL=sqlite:///./smart_pharma.db

# PostgreSQL for production (uncomment and configure)
# DATABASE_URL=postgresql+psycopg://postgres:password@localhost:5432/smart_pharma_db

# Application Settings
APP_ENV=development
DEBUG=true

# CORS Settings (comma-separated list of allowed origins)
# ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# API Settings
API_PREFIX=/ai
API_VERSION=1.0.0
